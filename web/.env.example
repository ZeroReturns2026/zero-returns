# SQLite file path (default: ./data/hey-tailor.db)
DB_PATH=./data/hey-tailor.db
PORT=3000
SHOPIFY_APP_URL=http://localhost:3000
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# During local dev, we don't verify the proxy HMAC. Set to "true" in production.
VERIFY_PROXY_SIGNATURE=false

# Zero Returns Google Sheet published-as-CSV URL.
# In Google Sheets: File → Share → Publish to web → Entire Document → CSV → Publish.
# Then paste the generated CSV URL here.
ZERO_RETURNS_CSV_URL=

# Reference measurements (zero-returns-sizing-master). Used by `npm run references:sync`.
# Publish each sheet tab separately: File → Share → Publish to web → choose tab → CSV → Publish.
FACTORY_MEASUREMENTS_CSV_URL=
HAND_MEASUREMENTS_CSV_URL=
